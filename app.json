{
  "expo": {
    "name": "Snakes & Ladders",
    "slug": "snakes-and-ladders",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0B1026",
    "splash": {
      "backgroundColor": "#1a1040",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.smaharjan.snakesandladders"
    },
    "android": {
      "package": "com.smaharjan.snakesandladders",
      "adaptiveIcon": {
        "backgroundColor": "#1a1040",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-status-bar",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow $(PRODUCT_NAME) to use your location to match the in-game sky to your local day and night."
        }
      ],
      "expo-audio"
    ]
  }
}
